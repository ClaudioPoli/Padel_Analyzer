{
  "video": {
    "supported_formats": [".mp4", ".mov", ".avi", ".mkv"],
    "target_fps": null,
    "target_resolution": null
  },
  "tracking": {
    "player_detection_confidence": 0.5,
    "ball_detection_confidence": 0.3,
    "max_tracking_distance": 100,
    "interpolate_missing": true,
    "max_interpolation_gap": 5,
    "use_keypoints_for_team": false
  },
  "field_detection": {
    "line_detection_threshold": 100,
    "corner_detection_tolerance": 10,
    "use_homography": true,
    "auto_calibrate": true
  },
  "field_keypoints": {
    "enabled": true,
    "model_path": "models/field_skeleton_yolo11m_pose5/weights/best.pt",
    "min_keypoint_confidence": 0.5,
    "min_detection_confidence": 0.25,
    "interpolate_missing": true,
    "temporal_smoothing": true,
    "smoothing_window": 5,
    "num_sample_frames": 10
  },
  "model": {
    "player_model": "yolov8n.pt",
    "ball_model": "yolov8n.pt",
    "device": "auto",
    "batch_size": 1
  },
  "pose": {
    "enabled": true,
    "pose_model": "yolov8n-pose.pt",
    "min_confidence": 0.25,
    "estimate_for_all_frames": false,
    "frame_sample_rate": 3
  },
  "action_recognition": {
    "enabled": true,
    "use_ml_model": false,
    "model_path": null,
    "buffer_size": 16,
    "min_action_confidence": 0.5
  }
}
